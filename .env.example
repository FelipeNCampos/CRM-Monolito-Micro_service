# ============================================================
# CRM Backend - Environment Variables
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# --- Aplicacao ---
APP_NAME="CRM Backend"
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# --- Seguranca JWT ---
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Banco de Dados PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=your-strong-password-here

# --- Configuracoes de Sessao ---
SESSION_INACTIVITY_MINUTES=60

# --- Rate Limiting (recuperacao de senha) ---
PASSWORD_RESET_RATE_LIMIT_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# --- Email / SMTP ---
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=no-reply@crm.local
MAIL_FROM_NAME="CRM Backend"
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Logs de Auditoria ---
# AUDIT_LOG_RETENTION_DAYS=365
